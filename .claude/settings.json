{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(env)",
      "Bash(env *)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(set)",
      "Bash(export -p)",
      "Bash(export)",
      "Bash(declare)",
      "Bash(declare *)",
      "Bash(typeset)",
      "Bash(typeset *)",
      "Bash(cat .env)",
      "Bash(cat .env*)",
      "Bash(cat *.env)",
      "Bash(cat *.env*)",
      "Bash(head .env*)",
      "Bash(head *.env*)",
      "Bash(tail .env*)",
      "Bash(tail *.env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(bat .env*)",
      "Bash(grep .env*)",
      "Bash(grep * .env*)",
      "Bash(rg .env*)",
      "Bash(echo $*)",
      "Bash(echo \"$*)",
      "Bash(printf $*)"
    ]
  }
}
