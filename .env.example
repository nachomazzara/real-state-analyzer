PORT=3000
CACHE_TTL_HOURS=24
MAX_CONCURRENCY=2
LOG_LEVEL=info
INCREMENTAL_STOP_AFTER=30
FULL_REFRESH_DAYS=7

# Claude Code CLI authentication for the agent-based scrapers.
# Two options (only one needed):
#   1) Mount ~/.claude (default in docker-compose.yml). Works on Linux when
#      `claude login` has been run and ~/.claude/.credentials.json exists.
#      Does NOT work on macOS because the host stores credentials in the
#      Keychain rather than in a file.
#   2) Set CLAUDE_CODE_OAUTH_TOKEN below. Generate one on the host with
#      `claude setup-token`. The container writes it to .credentials.json
#      automatically on first agent invocation.
# CLAUDE_CODE_OAUTH_TOKEN=

# Override the model used by the agent-based scrapers (optional).
# AGENT_MODEL=claude-sonnet-4-6

# USD rate used to convert ARS to USD. One of:
#   oficial (default)
#   blue
#   bolsa            (MEP — financial dollar)
#   contadoconliqui  (CCL)
#   mayorista
#   cripto
#   tarjeta
# FX_RATE_TYPE=oficial

# ─── Enrichment tuning ──────────────────────────────────────────────────────
# How many detail-page fetches each source runs in parallel during enrich.
# Defaults are conservative to avoid bot walls. Raise carefully.

# Other sources (argenprop, remax) — no anti-bot constraints, free to raise.
# ENRICH_CONCURRENCY=5

# MercadoLibre: cookies are refreshed before every request from ml-cookies.txt,
# so each navigation looks like a fresh authenticated session. Concurrency 8
# and no inter-request delay are safe. Raise carefully if cookies are fresh.
# ML_ENRICH_CONCURRENCY=8
# ML_ENRICH_DELAY_MS=0

# Zonaprop is behind Cloudflare. Each request gets a fresh session via cookie
# reset (we clear .zonaprop.com.ar cookies before every navigation), so going
# parallel is safe — Cloudflare can't link the requests. Default delay 0 ms
# since the cookie reset already prevents session tainting; raise only if a
# wall flares up again.
# ZONAPROP_ENRICH_CONCURRENCY=5
# ZONAPROP_ENRICH_DELAY_MS=0

# Agent fallback (Claude CLI). Used when a direct fetch can't get past the
# bot wall. Runs through Anthropic's IP, no per-source throttle. Higher =
# faster recovery but more concurrent claude processes spawned.
# AGENT_CONCURRENCY=6

# Cap on agent skill timeout in ms. Each escalated listing has this long to
# get back a parsed JSON result before being marked failed.
# AGENT_TIMEOUT_MS=300000

# Hard cap on detail-page enrichment per source per scrape job. Prevents an
# initial scrape from ballooning into hours of enrichment.
# ENRICH_LIMIT=10000

# ─── Source toggles ─────────────────────────────────────────────────────────
# Comma-separated list of sources to skip entirely (no scrape, no enrich).
# Useful when one source's bot wall is hot. Valid values: mercadolibre,
# argenprop, remax, zonaprop.
# DISABLED_SOURCES=

# Override the data dir (default ./data relative to repo root).
# DATA_DIR=/path/to/data
