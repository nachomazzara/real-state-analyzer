PORT=3000
CACHE_TTL_HOURS=24
MAX_CONCURRENCY=2
LOG_LEVEL=info
INCREMENTAL_STOP_AFTER=30
FULL_REFRESH_DAYS=7

# Claude Code CLI authentication for the agent-based scrapers.
# Two options (only one needed):
#   1) Mount ~/.claude (default in docker-compose.yml). Works on Linux when
#      `claude login` has been run and ~/.claude/.credentials.json exists.
#      Does NOT work on macOS because the host stores credentials in the
#      Keychain rather than in a file.
#   2) Set CLAUDE_CODE_OAUTH_TOKEN below. Generate one on the host with
#      `claude setup-token`. The container writes it to .credentials.json
#      automatically on first agent invocation.
# CLAUDE_CODE_OAUTH_TOKEN=

# Override the model used by the agent-based scrapers (optional).
# AGENT_MODEL=claude-sonnet-4-6

# USD rate used to convert ARS to USD. One of:
#   oficial (default)
#   blue
#   bolsa            (MEP — financial dollar)
#   contadoconliqui  (CCL)
#   mayorista
#   cripto
#   tarjeta
# FX_RATE_TYPE=oficial

# ─── Enrichment tuning ──────────────────────────────────────────────────────
# How many detail-page fetches each source runs in parallel during enrich.
# Defaults are conservative to avoid bot walls. Raise carefully.

# Other sources (argenprop, remax) — no anti-bot constraints, free to raise.
# ENRICH_CONCURRENCY=5

# MercadoLibre is CLI-only (see HOW_TO_SCRAP_ML.md). The env vars below are
# read by scripts/scrape-ml.js — it sets sensible defaults (1 channel,
# 5-15s per listing, 30-60s break every 50 listings) if not overridden.
# CHROME_CDP_URL=http://localhost:9222  # DevTools endpoint the script attaches to
# ML_CHANNELS=1                          # parallel tabs — keep at 1
# ML_DELAY_MIN_MS=5000
# ML_DELAY_MAX_MS=15000
# ML_BREAK_EVERY=50                      # "coffee break" cadence (0 = disable)
# ML_BREAK_MIN_MS=30000
# ML_BREAK_MAX_MS=60000
# ML_ABORT_AFTER_CONSECUTIVE_FAILS=5     # stop early when session is flagged (0 = never)

# Zonaprop is behind Cloudflare. Each request gets a fresh session via cookie
# reset (we clear .zonaprop.com.ar cookies before every navigation), so going
# parallel is safe — Cloudflare can't link the requests. Default delay 0/0 ms
# since the cookie reset already prevents session tainting; raise the MIN/MAX
# pair only if a wall flares up again.
# ZONAPROP_ENRICH_CONCURRENCY=5
# ZONAPROP_ENRICH_DELAY_MIN_MS=0
# ZONAPROP_ENRICH_DELAY_MAX_MS=0

# Agent fallback (Claude CLI). Used when a direct fetch can't get past the
# bot wall. Runs through Anthropic's IP, no per-source throttle. Higher =
# faster recovery but more concurrent claude processes spawned.
# AGENT_CONCURRENCY=6

# Cap on agent skill timeout in ms. Each escalated listing has this long to
# get back a parsed JSON result before being marked failed.
# AGENT_TIMEOUT_MS=300000

# Hard cap on detail-page enrichment per source per scrape job. Prevents an
# initial scrape from ballooning into hours of enrichment.
# ENRICH_LIMIT=10000

# ─── Source toggles ─────────────────────────────────────────────────────────
# Comma-separated list of sources to skip entirely (no scrape, no enrich).
# Useful when one source's bot wall is hot. Valid values: mercadolibre,
# argenprop, remax, zonaprop.
# DISABLED_SOURCES=

# Override the data dir (default ./data relative to repo root).
# DATA_DIR=/path/to/data

# ─── Sub-zones ──────────────────────────────────────────────────────────────
# Address extraction during enrichment → geocoding → H3 res-8 sub-zones with
# auto-derived labels. The UI's map view depends on this (needs lat/lng),
# so leave it on unless you know what you're doing.
# ENABLE_SUBZONES=true

# How many addresses to geocode per scrape run. The geocode_cache table
# remembers every successful lookup so subsequent runs are mostly cache hits;
# the cap matters mainly on the first pass over a fresh DB.
# GEOCODE_BATCH_LIMIT=500

# ─── Geocoding tunables ─────────────────────────────────────────────────────
# Number of parallel text-geocoder workers (USIG/Nominatim calls). USIG has
# no documented rate limit, so ~8 is fine. Nominatim is gated globally to
# ≥ 1s per request inside geocode.js so raising this doesn't affect it.
# GEO_CONCURRENCY=8

# When text geocoding fails on a Zonaprop listing, we open the detail page
# in Playwright and read coords from the map widget (Zonaprop lazy-loads
# a Google Maps iframe). These calls are heavy (~5-15s each), so they run
# gated separately. Default 2 concurrent — raise carefully.
# ZONAPROP_MAP_FALLBACK_CONCURRENCY=2
